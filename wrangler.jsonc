{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "treats",
  "main": "worker.js",
  "compatibility_date": "2026-06-29",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "treats-answers",
      "database_id": "PASTE_YOUR_D1_DATABASE_ID_HERE"
    }
  ]
}
